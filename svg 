<!DOCTYPE html>
<html>
<head>
    <title>SVG Sunflower</title>
</head>
<body>

<svg width="500" height="600" viewBox="0 0 500 600">

    <!-- Stem -->
    <rect x="245" y="250" width="10" height="250" fill="green"/>

    <!-- Leaves -->
    <ellipse cx="200" cy="350" rx="50" ry="25"
             fill="green"
             transform="rotate(-30 200 350)" />

    <ellipse cx="300" cy="420" rx="50" ry="25"
             fill="green"
             transform="rotate(30 300 420)" />

    <!-- Petals -->
    <g transform="translate(250,180)">
        <ellipse cx="0" cy="-90" rx="25" ry="70" fill="gold"/>
        <ellipse cx="0" cy="-90" rx="25" ry="70" fill="gold" transform="rotate(30)"/>
        <ellipse cx="0" cy="-90" rx="25" ry="70" fill="gold" transform="rotate(60)"/>
        <ellipse cx="0" cy="-90" rx="25" ry="70" fill="gold" transform="rotate(90)"/>
        <ellipse cx="0" cy="-90" rx="25" ry="70" fill="gold" transform="rotate(120)"/>
        <ellipse cx="0" cy="-90" rx="25" ry="70" fill="gold" transform="rotate(150)"/>
        <ellipse cx="0" cy="-90" rx="25" ry="70" fill="gold" transform="rotate(180)"/>
        <ellipse cx="0" cy="-90" rx="25" ry="70" fill="gold" transform="rotate(210)"/>
        <ellipse cx="0" cy="-90" rx="25" ry="70" fill="gold" transform="rotate(240)"/>
        <ellipse cx="0" cy="-90" rx="25" ry="70" fill="gold" transform="rotate(270)"/>
        <ellipse cx="0" cy="-90" rx="25" ry="70" fill="gold" transform="rotate(300)"/>
        <ellipse cx="0" cy="-90" rx="25" ry="70" fill="gold" transform="rotate(330)"/>
    </g>

    <!-- Flower Center -->
    <circle cx="250" cy="180" r="60" fill="#5C3317"/>
    
    <!-- Seed Pattern -->
    <g fill="#3B1F0B">
        <circle cx="250" cy="180" r="4"/>
        <circle cx="230" cy="165" r="4"/>
        <circle cx="270" cy="165" r="4"/>
        <circle cx="230" cy="195" r="4"/>
        <circle cx="270" cy="195" r="4"/>
        <circle cx="250" cy="150" r="4"/>
        <circle cx="250" cy="210" r="4"/>
        <circle cx="215" cy="180" r="4"/>
        <circle cx="285" cy="180" r="4"/>
    </g>

</svg>

</body>
</html>

